GHOSTCRAWLER_ENV=production
GHOSTCRAWLER_DATA_DIR=/app/data
GHOSTCRAWLER_TOR_SOCKS_HOST=tor
GHOSTCRAWLER_TOR_SOCKS_PORT=9050
GHOSTCRAWLER_ENABLE_DEMO_CONTENT=false
GHOSTCRAWLER_ENABLE_SEED_CATALOG=true
GHOSTCRAWLER_ENABLE_FRONTIER=true
GHOSTCRAWLER_COLLECTOR_INTERVAL_SECONDS=900
GHOSTCRAWLER_SEED_BATCH_LIMIT=12
GHOSTCRAWLER_SEED_BATCH_DEPTH=3
